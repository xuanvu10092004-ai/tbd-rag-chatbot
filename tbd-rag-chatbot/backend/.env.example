# Khoa API Google Gemini - bat buoc, khong duoc commit gia tri that
GEMINI_API_KEY=your_gemini_api_key_here

# Model tra loi chinh
# Mac dinh: gemini-3.5-flash
# Neu tai khoan hoac vung khong ho tro gemini-3.5-flash, doi thanh: gemini-2.5-flash
GEMINI_MODEL_ID=gemini-3.5-flash

# Model nhung van ban (embedding)
GEMINI_EMBED_MODEL=gemini-embedding-001

# ChromaDB - thu muc luu tru persistent
CHROMA_PERSIST_DIR=./chroma_db

# Ten collection trong ChromaDB
COLLECTION_NAME=tbd_knowledge_base

# Cau hinh ingestion URL
# So trang toi da moi lan goi ingest URLs
MAX_PAGES_PER_INGESTION=20
# Thoi gian cho toi da khi fetch URL (giay)
URL_REQUEST_TIMEOUT=10

# Cau hinh chunking (RecursiveCharacterTextSplitter)
# Kich thuoc chunk muc tieu (ky tu)
CHUNK_SIZE=800
# Do chong cheo giua cac chunk (ky tu)
CHUNK_OVERLAP=150

# So luong chunk truy xuat toi da moi cau hoi
TOP_K_RESULTS=4

# Nguong muc do lien quan (cosine distance)
# Gia tri nho hon = lien quan hon (0 = giong het, 1 = khac hoan toan)
# Da kiem tra voi du lieu TBD: nen dat 0.80-0.90 voi gemini-embedding-001
RELEVANCE_DISTANCE_THRESHOLD=0.85

# Lich su hoi thoai - so tin nhan toi da giu lai moi conversation (8-12 khuyen nghi)
MAX_HISTORY_MESSAGES=10

# CORS - cho phep frontend goi backend
FRONTEND_ORIGIN=http://localhost:5173
